#include "raylib.h"
#include "stdlib.h" 

#define MAX_PARTICULAS 100


typedef enum GameState
{
    MENU,
    GAME,
    INSTRUCTIONS,
    GAME_OVER
} GameState;

typedef struct Particula
{
    Vector2 posicao;
    Vector2 velocidade;
    float tamanho;
    float tempoVida;
    bool ativa;
    Color cor;
} Particula;


void CriarExplosao(Particula particulas[], Vector2 origem)
{
    for (int i = 0; i < MAX_PARTICULAS; i++)
    {
        if (!particulas[i].ativa)
        {
            particulas[i].ativa = true;
            particulas[i].posicao = origem;

            particulas[i].velocidade.x = GetRandomValue(-200, 200) / 100.0f;
            particulas[i].velocidade.y = GetRandomValue(-200, 200) / 100.0f;

            particulas[i].tamanho = GetRandomValue(3, 7);
            particulas[i].tempoVida = 0.8f;

            // Mantendo a paleta: partículas brilham em AMARELO ao explodir
            particulas[i].cor = YELLOW; 
        }
    }
}


int main(void)
{
    // Cria janela
    InitWindow(1000, 600, "Jogo da Minhoca - Sprite Sheet Animada");

    SetTargetFPS(60);

    
    Texture2D sprite = LoadTexture("player.png");

    int frames = 4;
    int frameAtual = 0;
    int larguraFrame = sprite.width / frames;
    int alturaFrame = sprite.height;
    
    float tempoAnimacao = 0;
    float velocidadAnimacao = 0.15f;

    

    
    Particula particulas[MAX_PARTICULAS] = { 0 };

    
    GameState estadoAtual = MENU;

    Vector2 jogador = { 500, 350 };
    float velocidade = 4.0f;

    Vector2 corpo[100];
    int tamanhoMinhoca = 3;

    Vector2 comida = { 300, 400 };

    int score = 0;
    int nivelVelocidade = 1;
    float tempo = 0;


    while (!WindowShouldClose())
    {
        float delta = GetFrameTime();

    
        tempoAnimacao += delta;

        if (tempoAnimacao >= velocidadAnimacao)
        {
            frameAtual++;
            if (frameAtual >= frames)
            {
                frameAtual = 0;
            }
            tempoAnimacao = 0;
        }


        if (estadoAtual == MENU)
        {
            if (IsKeyPressed(KEY_ENTER))
            {
                jogador = (Vector2){ 500, 350 };
                tamanhoMinhoca = 3;
                for (int i = 0; i < tamanhoMinhoca; i++) corpo[i] = jogador;
                score = 0;
                tempo = 0;
                nivelVelocidade = 1;
                velocidade = 4.0f;
                
                for (int i = 0; i < MAX_PARTICULAS; i++) particulas[i].ativa = false;

                estadoAtual = GAME;
            }

            if (IsKeyPressed(KEY_I))     estadoAtual = INSTRUCTIONS;
            if (IsKeyPressed(KEY_ESCAPE)) break;
        }
        else if (estadoAtual == INSTRUCTIONS)
        {
            if (IsKeyPressed(KEY_BACKSPACE)) estadoAtual = MENU;
        }
        else if (estadoAtual == GAME)
        {
            tempo += delta;

            for (int i = tamanhoMinhoca - 1; i > 0; i--)
            {
                corpo[i] = corpo[i - 1];
            }
            corpo[0] = jogador;

            if (IsKeyDown(KEY_RIGHT)) jogador.x += velocidade;
            if (IsKeyDown(KEY_LEFT))  jogador.x -= velocidade;
            if (IsKeyDown(KEY_UP))    jogador.y -= velocidade;
            if (IsKeyDown(KEY_DOWN))  jogador.y += velocidade;

            if (jogador.y < 135) jogador.y = 135; 

            if (CheckCollisionCircles(jogador, 15, comida, 10))
            {
                CriarExplosao(particulas, comida);

                score += 10;
                if (tamanhoMinhoca < 100) tamanhoMinhoca += 2;

                comida.x = (float)(GetRandomValue(40, 960));
                comida.y = (float)(GetRandomValue(150, 540));
            }

            if (IsKeyPressed(KEY_SPACE))
            {
                nivelVelocidade++;
                velocidade += 0.5f;
                if (nivelVelocidade > 10)
                {
                    nivelVelocidade = 1;
                    velocidade = 4.0f;
                }
            }

            for (int i = 10; i < tamanhoMinhoca; i++)
            {
                if (CheckCollisionCircles(jogador, 12, corpo[i], 12))
                {
                    estadoAtual = GAME_OVER;
                }
            }

            if (IsKeyPressed(KEY_G)) estadoAtual = GAME_OVER;
        }
        else if (estadoAtual == GAME_OVER)
        {
            if (IsKeyPressed(KEY_R))
            {
                jogador = (Vector2){ 500, 350 };
                tamanhoMinhoca = 3;
                for (int i = 0; i < tamanhoMinhoca; i++) corpo[i] = jogador;
                score = 0;
                tempo = 0;
                estadoAtual = GAME;
            }
            if (IsKeyPressed(KEY_M)) estadoAtual = MENU;
        }

        // UPDATE DAS PARTÍCULAS
        for (int i = 0; i < MAX_PARTICULAS; i++)
        {
            if (particulas[i].ativa)
            {
                particulas[i].posicao.x += particulas[i].velocidade.x * 100 * delta;
                particulas[i].posicao.y += particulas[i].velocidade.y * 100 * delta;
                particulas[i].tempoVida -= delta;
                particulas[i].tamanho -= delta * 4;

                if (particulas[i].tempoVida <= 0 || particulas[i].tamanho <= 0)
                {
                    particulas[i].ativa = false;
                }
            }
        }

        Rectangle source = {
            frameAtual * larguraFrame,
            0,
            larguraFrame,
            alturaFrame
        };

        Rectangle dest = {
            jogador.x,
            jogador.y,
            40, // Largura final que a cabeça terá na tela
            40  // Altura final que a cabeça terá na tela
        };

        // Define a origem do desenho no meio do frame para que a rotação e colisão fiquem perfeitas
        Vector2 centroSprite = { 20, 20 };

        // =========================================
        // DRAW
        // =========================================

        BeginDrawing();
        ClearBackground(BLACK);

        if (estadoAtual == MENU)
        {
            DrawText("MINHOCA ARCADE", 340, 180, 36, PINK);
            DrawText("Pressione ENTER para iniciar", 320, 280, 24, YELLOW);
            DrawText("Pressione I para Instrucoes", 335, 330, 24, YELLOW);
        }
        else if (estadoAtual == INSTRUCTIONS)
        {
            DrawText("INSTRUCOES", 400, 150, 36, PINK);
            DrawText("Use as setas para mover a minhoca.", 280, 250, 22, YELLOW);
            DrawText("Pegue as frutas amarelas para crescer e explodir particulas!", 170, 300, 22, PINK);
            DrawText("Pressione BACKSPACE para voltar.", 310, 400, 22, YELLOW);
        }
        else if (estadoAtual == GAME)
        {
            // DESENHA COMIDA (Bolinha Amarela)
            DrawCircleV(comida, 10, YELLOW);

            // DESENHA O CORPO DA MINHOCA (Bolinhas Pink menores)
            for (int i = 0; i < tamanhoMinhoca; i++)
            {
                DrawCircleV(corpo[i], 12, PINK);
            }

            
            DrawTexturePro(
                sprite,
                source,
                dest,
                centroSprite,
                0,
                PINK 
            );

            // DESENHA AS PARTÍCULAS DA EXPLOSÃO (Amarelas)
            for (int i = 0; i < MAX_PARTICULAS; i++)
            {
                if (particulas[i].ativa)
                {
                    DrawCircleV(particulas[i].posicao, particulas[i].tamanho, particulas[i].cor);
                }
            }

            // =========================================
            // HUD DESIGN (Tons de Pink e Amarelo)
            // =========================================
            DrawRectangle(0, 0, 1000, 115, DARKGRAY);
            DrawLine(0, 115, 1000, 115, PINK);

            DrawText("SNAKE GAME", 20, 15, 28, YELLOW);
            DrawText(TextFormat("Frutas: %d", score / 10), 20, 65, 20, YELLOW);
            DrawText(TextFormat("Tamanho: %d", tamanhoMinhoca), 220, 65, 20, PINK);

            // Barra de Crescimento
            DrawRectangle(220, 40, 200, 20, BLACK);
            DrawRectangle(220, 40, tamanhoMinhoca * 2, 20, PINK); 
            DrawRectangleLines(220, 40, 200, 20, YELLOW);         

            DrawText(TextFormat("Velocidade: Nivel %d", nivelVelocidade), 470, 65, 20, YELLOW);
            DrawText(TextFormat("Tempo: %.1f s", tempo), 750, 65, 20, PINK);
            
            // Info extra da Sprite na tela
            DrawText(TextFormat("Frame Cabeça: %d", frameAtual), 470, 15, 16, YELLOW);
            DrawText("ESPACO = Aumentar Velocidade", 20, 565, 18, YELLOW);
        }
        else if (estadoAtual == GAME_OVER)
        {
            DrawText("GAME OVER", 370, 180, 48, PINK);
            DrawText(TextFormat("Pontuacao final: %d pontos", score), 360, 260, 22, YELLOW);
            DrawText("Pressione R para Reiniciar", 345, 340, 22, YELLOW);
            DrawText("Pressione M para ir ao Menu", 340, 380, 22, PINK);
        }

        EndDrawing();
    }

    UnloadTexture(sprite);
    CloseWindow();
    
    return 0;
}
