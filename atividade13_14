    }
}

static void DrawM2(int chances,float timer,bool vitoria){
    ClearBackground((Color){15,12,28,255});
    for(int i=0;i<6;i++){
        float cx=50.f+i*90,cy=60.f+sinf(GetTime()*1.2f+i)*8;
        DrawCircle((int)cx,(int)cy,22,(Color){60,60,60,(unsigned char)(80+i*10)});
    }
    
    DrawRectangle(JX0-5,JY0,COLUNAS*JW+10,ANDARES*JH,(Color){60,55,70,255});
    
    for(int r=0;r<ANDARES;r++) for(int c=0;c<COLUNAS;c++){
        int idx=r*COLUNAS+c;
        float wx=JX0+c*JW, wy=JY0+r*JH;
        Color wc;
        if(jans[idx].fogo>0){
            unsigned char rr=200,gg=(unsigned char)(40+(1.f-jans[idx].fogo)*100);
            wc=(Color){rr,gg,0,255};
            float oy=sinf(GetTime()*4+c+r)*6;
            DrawCircle((int)(wx+JW/2),(int)(wy+JH/2+oy),14,(Color){255,80,0,200});
            DrawCircle((int)(wx+JW/2),(int)(wy+JH/2-10+oy),9,(Color){255,180,0,180});
        } else {
            wc=jans[idx].salvo?(Color){100,200,255,180}:(Color){40,50,80,200};
        }
        DrawRectangle((int)wx,(int)wy,JW-4,JH-4,wc);
        DrawRectangleLines((int)wx,(int)wy,JW-4,JH-4,(Color){20,20,30,255});
        if(jans[idx].figurante&&jans[idx].fogo>0) DrawFigurante((int)wx,(int)wy,jans[idx].fogo);
    }
    
    for(int i=0;i<MJT;i++){if(!jts[i].on)continue;
        Color wc={100,180,255,(unsigned char)(jts[i].a*255)};
        DrawCircle((int)jts[i].x,(int)jts[i].y,5,wc);
        DrawCircle((int)jts[i].x-4,(int)jts[i].y-4,3,(Color){180,220,255,(unsigned char)(jts[i].a*200)});
    }
    
    int cx=camX2;
    DrawRectangle(cx,H-100,130,50,(Color){200,30,30,255});
    DrawRectangle(cx+5,H-120,55,25,(Color){200,30,30,255});
    DrawRectangle(cx+8,H-118,30,18,(Color){180,220,255,200});
    DrawRectangle(cx+70,H-98,55,8,(Color){150,20,20,255});
    DrawCircle(cx+20,H-50,18,(Color){30,30,30,255}); DrawCircle(cx+20,H-50,10,(Color){80,80,80,255});
    DrawCircle(cx+100,H-50,18,(Color){30,30,30,255}); DrawCircle(cx+100,H-50,10,(Color){80,80,80,255});
    DrawRectangle(cx,H-50,130,5,(Color){160,160,160,255});
    
    float rad=mangAngle*(PI/180.f);
    int mx=cx+60, my=H-90;
    DrawLine(mx,my,mx+(int)(cosf(rad)*45),my+(int)(sinf(rad)*45),(Color){80,200,80,255});
    DrawCircle(mx+(int)(cosf(rad)*45),my+(int)(sinf(rad)*45),5,(Color){200,120,0,255});
    
    DrawRectangle(cx+50,H-108,30,10,(Color){255,255,0,255});
    DrawCircle(cx+55,H-108,5,(int)(GetTime()*4)%2==0?(Color){255,50,50,255}:(Color){50,50,255,255});
    DrawCircle(cx+75,H-108,5,(int)(GetTime()*4)%2==0?(Color){50,50,255,255}:(Color){255,50,50,255});
    
    DrawHUD(chances,timer,"ESPACO: Jato de agua",2);
    char inf[64]; sprintf(inf,"Fogo apagado: %d/%d",fogoApagado2,fogoTotal2);
    DrawText(inf,W/2-MeasureText(inf,16)/2,H-26,16,(Color){100,200,255,255});
    if(vitoria){ DrawMissaoConcluida(2,timer,"Predio salvo!"); DrawFoguetes(); }
}

