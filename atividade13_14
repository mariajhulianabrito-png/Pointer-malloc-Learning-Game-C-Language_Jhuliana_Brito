            DrawRectangle(0,80,W,80,(Color){180,20,0,230});
            DrawRectangle(0,83,W,4,(Color){255,190,0,255}); DrawRectangle(0,154,W,4,(Color){255,190,0,255});
            const char *t1="BOMBEIRO HEROI";
            DrawText(t1,W/2-MeasureText(t1,36)/2+2,105,36,(Color){0,0,0,180});
            DrawText(t1,W/2-MeasureText(t1,36)/2, 103,36,(Color){255,230,50,255});
            DrawText("5 MISSOES - SEJA O HEROI!",W/2-MeasureText("5 MISSOES - SEJA O HEROI!",17)/2,163,17,(Color){255,170,90,255});
            const char *ms[]={"M1: Suba a escada em chamas","M2: Apague o predio com a mangueira",
