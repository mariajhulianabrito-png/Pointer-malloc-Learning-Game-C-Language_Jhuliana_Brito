#include "raylib.h"

typedef enum { MENU, GAME, INSTRUCTIONS, GAME_OVER } GameState;

int main(void)
{
    const int numPlataformas = 7;
    InitWindow(1280, 768, "Minhoca - Movimento Livre 2D");
    SetTargetFPS(60);

    // Recursos e Estados
    Texture2D sprite = LoadTexture("player.png");
    int frameAtual = 0;
    float tempoAnimacao = 0;
    GameState estadoAtual = MENU;

    // Movimentação e Câmera
    Vector2 jogador = { 200, 300 };
    Vector2 corpo[100] = { 0 };
    int tamanhoMinhoca = 3;
    float velX = 300.0f; // Velocidade de movimento em todas as direções

    Camera2D camera = { (Vector2){ 640, 384 }, jogador, 0.0f, 1.0f };
    Vector2 comida = { 512, 128 };
    int score = 0;
    float tempo = 0;

    // Definição das paredes e obstáculos do mapa
    Rectangle plataformas[] = {
        { 0, 704, 1280, 64 },    // Chão
        { 0, 0, 1280, 64 },      // Teto
        { 0, 0, 64, 768 },        // Parede esquerda
        { 1216, 0, 64, 768 },     // Parede direita
        { 448, 192, 256, 64 },    // Obstáculo 1
        { 192, 384, 192, 64 },    // Obstáculo 2
        { 768, 384, 256, 64 }     // Obstáculo 3
    };

    while (!WindowShouldClose())
    {
        float delta = GetFrameTime();

        // Animação da Sprite
        tempoAnimacao += delta;
        if (tempoAnimacao >= 0.15f) {
            frameAtual = (frameAtual + 1) % 4;
            tempoAnimacao = 0;
        }

        if (estadoAtual == GAME)
        {
            tempo += delta;
            Vector2 antigaPos = jogador;

            // CONTROLES REATIVADOS: Agora move livremente para todas as direções
            if (IsKeyDown(KEY_RIGHT)) jogador.x += velX * delta;
            if (IsKeyDown(KEY_LEFT))  jogador.x -= velX * delta;
            if (IsKeyDown(KEY_UP))    jogador.y -= velX * delta; // Cima livre!
            if (IsKeyDown(KEY_DOWN))  jogador.y += velX * delta; // Baixo livre!

            // Resolução de Colisão com as Paredes (Empurra para fora do bloco)
            Rectangle jogadorRect = { jogador.x - 22, jogador.y - 22, 44, 44 };
            for (int i = 0; i < numPlataformas; i++)
            {
                if (CheckCollisionRecs(jogadorRect, plataformas[i]))
                {
                    // Se colidir, o jogador retorna para a última posição válida (antes de bater)
                    jogador = antigaPos;
                }
            }

            // Atualiza o rastro do corpo apenas se a minhoca realmente andou
            if (jogador.x != antigaPos.x || jogador.y != antigaPos.y) {
                for (int i = tamanhoMinhoca - 1; i > 0; i--) corpo[i] = corpo[i - 1];
                corpo[0] = antigaPos;
            }

            // Câmera foca na cabeça da minhoca no centro
            camera.target = jogador;

            // Coleta da Fruta Amarela
            if (CheckCollisionCircles(jogador, 16, comida, 12)) {
                score += 10;
                if (tamanhoMinhoca < 100) tamanhoMinhoca += 3;
                comida = (Vector2){ (float)GetRandomValue(100, 1100), (float)GetRandomValue(100, 600) };
            }

            // Game over se bater no próprio corpo
            for (int i = 15; i < tamanhoMinhoca; i++) {
                if (CheckCollisionCircles(jogador, 10, corpo[i], 10)) estadoAtual = GAME_OVER;
            }
        }
        else if (IsKeyPressed(KEY_ENTER) && (estadoAtual == MENU || estadoAtual == GAME_OVER))
        {
            // Inicializa ou reinicia variáveis ao apertar ENTER
            jogador = (Vector2){ 200, 300 };
            tamanhoMinhoca = 3;
            score = 0; tempo = 0;
            estadoAtual = GAME;
        }

        // =========================================
        // RENDERIZAÇÃO
        // =========================================
        BeginDrawing();
        ClearBackground(BLACK);

        if (estadoAtual == GAME)
        {
            BeginMode2D(camera);
                // Desenha os obstáculos em Rosa Pink
                for (int i = 0; i < numPlataformas; i++) {
                    DrawRectangleRec(plataformas[i], PINK);
                    DrawRectangleLinesEx(plataformas[i], 2, MAROON);
                }
                
                // Desenha a fruta Amarela
                DrawCircleV(comida, 12, YELLOW); 
                
                // Desenha o corpo em Rosa Pink
                for (int i = 0; i < tamanhoMinhoca; i++) DrawCircleV(corpo[i], 14, PINK); 
                
                // Desenha a cabeça usando sua Sprite Sheet animada
                DrawTexturePro(sprite, (Rectangle){ frameAtual * (sprite.width / 4), 0, sprite.width / 4, sprite.height },
                               (Rectangle){ jogador.x, jogador.y, 44, 44 }, (Vector2){ 22, 22 }, 0, PINK);
            EndMode2D();

            // HUD Estática (Fixa na tela)
            DrawRectangle(0, 0, 1280, 80, ColorAlpha(DARKGRAY, 0.8f));
            DrawText(TextFormat("PONTOS: %d  |  CORPO: %d  |  TEMPO: %.1f s", score, tamanhoMinhoca, tempo), 30, 25, 24, YELLOW);
        }
        else 
        {
            // Telas de Menu / Game Over dinâmicas
            char* txtPrincipal = (estadoAtual == MENU) ? "MINHOCA ARCADE 2D" : "GAME OVER";
            char* txtSecundario = (estadoAtual == MENU) ? "Use as SETAS para se mover | ENTER para iniciar" : "Pressione ENTER para reiniciar";
            DrawText(txtPrincipal, 640 - MeasureText(txtPrincipal, 36)/2, 300, 36, PINK);
            DrawText(txtSecundario, 640 - MeasureText(txtSecundario, 20)/2, 400, 20, YELLOW);
        }

        EndDrawing();
    }

    UnloadTexture(sprite);
    CloseWindow();
    return 0;
}
