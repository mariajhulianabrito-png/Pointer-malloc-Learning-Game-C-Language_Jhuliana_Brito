                              "M5: Escape pelo helicoptero!"};
            for(int i=0;i<5;i++) DrawText(ms[i],60,240+i*36,17,(Color){200,200,220,220});
            DrawBombeiro(260,490,true,(int)(GetTime()*10));
            Rectangle bp={170,600,260,52}; bool hov=CheckCollisionPointRec(mouse,bp);
            DrawRectangleRounded(bp,0.3f,8,hov?(Color){255,55,0,255}:(Color){170,25,0,255});
            DrawRectangleRoundedLines(bp,0.3f,8,(Color){255,200,0,255});
