static void UpdM4(float dt){
    if(IsKeyDown(KEY_LEFT)||IsKeyDown(KEY_A))  camX4-=3;
    if(IsKeyDown(KEY_RIGHT)||IsKeyDown(KEY_D)) camX4+=3;
    if(camX4<0)camX4=0; if(camX4>W-110)camX4=W-110;
    if(IsKeyDown(KEY_UP)||IsKeyDown(KEY_W))    mangAngle4-=2.f;
    if(IsKeyDown(KEY_DOWN)||IsKeyDown(KEY_S))  mangAngle4+=2.f;
    if(mangAngle4>-10.f)mangAngle4=-10.f; if(mangAngle4<-170.f)mangAngle4=-170.f;
    if(IsKeyPressed(KEY_SPACE)){
        for(int i=0;i<MJT;i++) if(!jts[i].on){
            float rad=mangAngle4*(PI/180.f);
            jts[i]=(Jato){camX4+55,H-95,cosf(rad)*16.f,sinf(rad)*16.f,1.f,true};
            break;
        }
    }
    
    for(int i=0;i<MJT;i++){if(!jts[i].on)continue;
        jts[i].x+=jts[i].vx; jts[i].y+=jts[i].vy; jts[i].vy+=0.3f;
        jts[i].a-=0.01f; if(jts[i].a<=0||jts[i].y>H){jts[i].on=false;continue;}
        for(int b=0;b<6;b++){if(!barris[b].on)continue;
            if(jts[i].x>barris[b].x&&jts[i].x<barris[b].x+30&&
               jts[i].y>barris[b].y&&jts[i].y<barris[b].y+50){
                barris[b].hp--;
                jts[i].on=false;
                if(barris[b].hp<=0){barris[b].on=false;barrisApagados4++;
                    for(int p=0;p<8;p++) EmitPart(barris[b].x+15,barris[b].y);}
            }
        }
    }
    
    for(int b=0;b<6;b++){if(!barris[b].on)continue;
        barris[b].x+=barris[b].vx*dt*60;
        if(barris[b].x<0||barris[b].x>W-30)barris[b].vx*=-1;
    }
}

