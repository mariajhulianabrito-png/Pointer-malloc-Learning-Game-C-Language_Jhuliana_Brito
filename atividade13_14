#include "raylib.h"

// =========================================
// MAIN
// =========================================

int main(void)
{
    // Cria janela
    InitWindow(1000, 600, "Cobrinha HUD - Pink & Amarelo");

    // Define FPS
    SetTargetFPS(60);

    // =========================================
    // JOGADOR (COBRINHA)
    // =========================================

    // Posição inicial
    Vector2 jogador = { 480, 300 };

    // Velocidade base
    float velocidade = 4.0f;

    // =========================================
    // HUD TEMÁTICA DA COBRINHA
    // =========================================

    // Pontuação (Frutas comidas)
    int score = 0;

    // Tamanho atual da cobra
    int tamanhoCobra = 10; 

    // Nível de Velocidade
    int nivelVelocidade = 1;

    // Tempo de jogo
    float tempo = 0;

    // =========================================
    // LOOP PRINCIPAL
    // =========================================

    while (!WindowShouldClose())
    {
        // =========================================
        // UPDATE
        // =========================================

        // Atualiza tempo
        tempo += GetFrameTime();

        // Movimento direita
        if (IsKeyDown(KEY_RIGHT))
            jogador.x += velocidade;

        // Movimento esquerda
        if (IsKeyDown(KEY_LEFT))
            jogador.x -= velocidade;

        // Movimento cima
        if (IsKeyDown(KEY_UP))
            jogador.y -= velocidade;

        // Movimento baixo
        if (IsKeyDown(KEY_DOWN))
            jogador.y += velocidade;

        // Simula comer fruta (Ganha pontos e cresce)
        if (IsKeyPressed(KEY_P))
        {
            score += 10;
            tamanhoCobra += 5; 

            if (tamanhoCobra > 100)
                tamanhoCobra = 100; 
        }

        // Simula colisão/dano (Diminui o tamanho da cobra)
        if (IsKeyPressed(KEY_H))
        {
            tamanhoCobra -= 5;

            if (tamanhoCobra < 0)
                tamanhoCobra = 0;
        }

        // Simula alterar o nível de velocidade com ESPAÇO
        if (IsKeyPressed(KEY_SPACE))
        {
            nivelVelocidade++;
            velocidade += 0.5f;

            if (nivelVelocidade > 10) 
            {
                nivelVelocidade = 1;
                velocidade = 4.0f;
            }
        }

        // =========================================
        // DRAW
        // =========================================

        BeginDrawing();

        // Fundo escuro para destacar o Pink e o Amarelo
        ClearBackground(BLACK);

        // =========================================
        // MUNDO DO JOGO
        // =========================================

        // Desenha cabeça da cobrinha em PINK
        DrawRectangleV(
            jogador,
            (Vector2){40, 40},
            PINK
        );

        // =========================================
        // HUD
        // =========================================

        // Fundo da HUD (Cinza bem escuro para dar contraste)
        DrawRectangle(
            0,
            0,
            1000,
            115,
            DARKGRAY
        );

        // Linha separadora da HUD em PINK
        DrawLine(
            0,
            115,
            1000,
            115,
            PINK
        );

        // Título do Jogo em AMARELO
        DrawText(
            "SNAKE GAME ARCADE",
            20,
            15,
            28,
            YELLOW
        );

        // Score (Frutas) em AMARELO
        DrawText(
            TextFormat("Frutas: %d", score / 10), 
            20,
            65,
            20,
            YELLOW
        );

        // Texto do Comprimento/Tamanho em PINK
        DrawText(
            TextFormat("Tamanho: %d", tamanhoCobra),
            220,
            65,
            20,
            PINK
        );

        // =========================================
        // BARRA DE COMPRIMENTO (CRESCIMENTO)
        // =========================================

        // Fundo da barra (Preto para destacar o preenchimento)
        DrawRectangle(
            220,
            40,
            200,
            20,
            BLACK
        );

        // Progresso do crescimento preenche em PINK
        DrawRectangle(
            220,
            40,
            tamanhoCobra * 2,
            20,
            PINK
        );

        // Borda da barra em AMARELO
        DrawRectangleLines(
            220,
            40,
            200,
            20,
            YELLOW
        );

        // Velocidade atual em AMARELO
        DrawText(
            TextFormat("Velocidade: Nivel %d", nivelVelocidade),
            470,
            65,
            20,
            YELLOW
        );

        // Tempo em PINK
        DrawText(
            TextFormat("Tempo: %.1f s", tempo),
            750,
            65,
            20,
            PINK
        );

        // Texto explicativo na parte inferior da tela em AMARELO
        DrawText(
            "P = Comer Fruta | H = Bater no Corpo | ESPACO = Aumentar Marcha/Velocidade",
            20,
            560,
            18,
            YELLOW
        );

        EndDrawing();
    }

    // Fecha janela
    CloseWindow();

    return 0;
}
