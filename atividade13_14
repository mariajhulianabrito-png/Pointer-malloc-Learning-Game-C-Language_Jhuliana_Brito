#include "raylib.h"
#include <stdlib.h>

#define MAX_PLAT 8
#define TELA_L 600
#define TELA_A 800

typedef enum { MENU, JOGO, GAMEOVER } State;
typedef struct { Rectangle r; int tipo; int dirX; bool ativa; } Plat;

void NovaPlat(Plat *p, float y) {
    p->r = (Rectangle){ GetRandomValue(0, TELA_L - 100), y, 100, 15 };
    p->ativa = true; p->dirX = (GetRandomValue(0, 1) == 0) ? -1 : 1;
    int c = GetRandomValue(0, 100); p->tipo = (c < 60) ? 0 : (c < 85 ? 1 : 2);
}

int main(void) {
    InitWindow(TELA_L, TELA_A, "Jump Game"); SetTargetFPS(60);
    State st = MENU; int hi = 0, score = 0;
    Vector2 plPos = { 300, 600 }; float velY = 0;
    Plat plats[MAX_PLAT];
    Rectangle bPlay = { 150, 350, 300, 60 }, bRest = { 150, 450, 300, 60 };

    for (int i = 0; i < MAX_PLAT; i++) NovaPlat(&plats[i], TELA_A - (i * 110) - 50);
    plats[0] = (Plat){ { 250, 700, 100, 15 }, 0, 1, true };

    while (!WindowShouldClose()) {
        Vector2 m = GetMousePosition();

        if (st == JOGO) {
            if (IsKeyDown(KEY_LEFT) || IsKeyDown(KEY_A)) plPos.x -= 6.0f;
            if (IsKeyDown(KEY_RIGHT) || IsKeyDown(KEY_D)) plPos.x += 6.0f;
            if (plPos.x < -40) plPos.x = TELA_L; else if (plPos.x > TELA_L) plPos.x = -40;

            velY += 0.4f; plPos.y += velY; // Gravidade estável por frame
            if (plPos.y > TELA_A) { if (score > hi) hi = score; st = GAMEOVER; }

            if (plPos.y < TELA_A / 2) {
                float diff = (TELA_A / 2) - plPos.y; plPos.y = TELA_A / 2; score += (int)diff;
                for (int i = 0; i < MAX_PLAT; i++) {
                    plats[i].r.y += diff;
                    if (plats[i].r.y > TELA_A) NovaPlat(&plats[i], plats[i].r.y - TELA_A);
                }
            }
        } else if (IsMouseButtonPressed(MOUSE_LEFT_BUTTON)) {
            if (st == MENU && CheckCollisionPointRec(m, bPlay)) st = JOGO;
            else if (st == GAMEOVER && CheckCollisionPointRec(m, bRest)) {
                plPos = (Vector2){ 300, 600 }; velY = 0; score = 0; st = JOGO;
                for (int i = 0; i < MAX_PLAT; i++) NovaPlat(&plats[i], TELA_A - (i * 110) - 50);
                plats[0] = (Plat){ { 250, 700, 100, 15 }, 0, 1, true };
            }
        }

        BeginDrawing(); ClearBackground(SKYBLUE);
        if (st == JOGO) {
            for (int i = 0; i < MAX_PLAT; i++) if (plats[i].ativa) {
                if (plats[i].tipo == 1) {
                    plats[i].r.x += plats[i].dirX * 3.0f;
                    if (plats[i].r.x <= 0 || plats[i].r.x >= TELA_L - 100) plats[i].dirX *= -1;
                }
                if (velY > 0 && CheckCollisionRecs((Rectangle){plPos.x, plPos.y, 40, 40}, plats[i].r) && plPos.y + 40 <= plats[i].r.y + 12) {
                    if (plats[i].tipo == 2) plats[i].ativa = false; else velY = -13.0f; // Impulso do pulo fixado
                }
                DrawRectangleRec(plats[i].r, plats[i].tipo == 0 ? GREEN : (plats[i].tipo == 1 ? ORANGE : RED));
            }
            DrawRectangle(plPos.x, plPos.y, 40, 40, PURPLE);
            DrawText(TextFormat("SCORE: %d", score), 20, 15, 22, BROWN);
        } else {
            bool menu = (st == MENU); Rectangle b = menu ? bPlay : bRest;
            DrawText(menu ? "JUMP GAME" : "GAME OVER", TELA_L/2 - MeasureText(menu ? "JUMP GAME" : "GAME OVER", 40)/2, 200, 40, menu ? DARKBLUE : RED);
            DrawRectangleRounded(b, 0.3f, 10, CheckCollisionPointRec(m, b) ? BLUE : DARKBLUE);
            DrawText(menu ? "JOGAR" : "REINICIAR", b.x + b.width/2 - MeasureText(menu ? "JOGAR" : "REINICIAR", 24)/2, b.y + 18, 24, WHITE);
        }
        EndDrawing();
    }
    CloseWindow(); return 0;
}
