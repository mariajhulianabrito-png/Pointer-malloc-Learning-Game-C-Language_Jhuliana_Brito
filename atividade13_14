static int camX2;
static float mangAngle;
static int fogoTotal2, fogoApagado2;

static void InitM2(void){
    fogoTotal2=0; fogoApagado2=0;
    for(int r=0;r<ANDARES;r++) for(int c=0;c<COLUNAS;c++){
        int idx=r*COLUNAS+c;
        jans[idx].col=c; jans[idx].row=r;
        jans[idx].fogo=(GetRandomValue(0,100)<70)?1.f:0.f;
        jans[idx].salvo=false;
        jans[idx].figurante=(jans[idx].fogo>0.5f && GetRandomValue(0,100)<60);
        if(jans[idx].fogo>0) fogoTotal2++;
    }
    camX2=W/2-60; mangAngle=0.f;
    ResetJatos();
}

static void FireJato(void){
    for(int i=0;i<MJT;i++) if(!jts[i].on){
        float rad=mangAngle*(PI/180.f);
        // Velocidade ligeiramente ajustada de 14.f para 15.f para um arco perfeito
        jts[i]=(Jato){(float)(camX2+60),(float)(H-90),cosf(rad)*15.f,sinf(rad)*15.f,1.f,true};
        break;
    }
}

static void UpdM2(float dt){
    if(IsKeyDown(KEY_LEFT)||IsKeyDown(KEY_A))  camX2-=3;
    if(IsKeyDown(KEY_RIGHT)||IsKeyDown(KEY_D)) camX2+=3;
    if(camX2<0)camX2=0; if(camX2>W-130)camX2=W-130;
    if(IsKeyDown(KEY_UP)||IsKeyDown(KEY_W))   mangAngle-=1.5f;
    if(IsKeyDown(KEY_DOWN)||IsKeyDown(KEY_S)) mangAngle+=1.5f;
    if(mangAngle>-20.f)mangAngle=-20.f; if(mangAngle<-160.f)mangAngle=-160.f;
    if(IsKeyPressed(KEY_SPACE)) FireJato();
    
    for(int i=0;i<MJT;i++){if(!jts[i].on)continue;
        jts[i].x+=jts[i].vx; jts[i].y+=jts[i].vy; jts[i].vy+=0.32f; // Gravidade ligeiramente reduzida para melhor alcance
        jts[i].a-=0.012f; if(jts[i].a<=0||jts[i].y>H){jts[i].on=false;continue;}
        
        for(int r=0;r<ANDARES;r++) for(int c=0;c<COLUNAS;c++){
            int idx=r*COLUNAS+c;
            if(jans[idx].fogo<=0)continue;
            float wx=JX0+c*JW, wy=JY0+r*JH;
            if(jts[i].x>=wx&&jts[i].x<=wx+JW&&jts[i].y>=wy&&jts[i].y<=wy+JH){
                jans[idx].fogo-=0.18f;
                if(jans[idx].fogo<=0){jans[idx].fogo=0;jans[idx].salvo=true;fogoApagado2++;}
                jts[i].on=false;
            }
        }
    }
    
    static float espT=0; espT+=dt;
    if(espT>4.f){ espT=0;
        for(int r=0;r<ANDARES;r++) for(int c=0;c<COLUNAS;c++){
            int idx=r*COLUNAS+c;
            if(jans[idx].fogo>0) jans[idx].fogo+=0.08f;
            if(jans[idx].fogo>1.f)jans[idx].fogo=1.f;
        }
    }
}

