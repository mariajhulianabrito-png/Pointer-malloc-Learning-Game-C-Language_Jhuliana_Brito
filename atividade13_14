            DrawRectangle((int)top.x-8,(int)top.y-34,(int)top.width+16,28,(Color){0,170,0,210});
            DrawText("CHEGADA",(int)(top.x+top.width/2-MeasureText("CHEGADA",13)/2),(int)(top.y-29),13,WHITE);
