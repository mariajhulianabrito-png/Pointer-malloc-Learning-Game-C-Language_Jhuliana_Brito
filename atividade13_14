// =========================================
// IMPORTA BIBLIOTECAS
// =========================================

#include "raylib.h"
#include "stdlib.h" // Usado para a função rand() da comida

// =========================================
// CONSTANTES
// =========================================

#define MAX_PARTICULAS 100

// =========================================
// STRUCTS
// =========================================

typedef enum GameState
{
    MENU,
    GAME,
    INSTRUCTIONS,
    GAME_OVER
} GameState;

typedef struct Particula
{
    Vector2 posicao;
    Vector2 velocidade;
    float tamanho;
    float tempoVida;
    bool ativa;
    Color cor;
} Particula;

// =========================================
// FUNÇÃO PARA CRIAR EXPLOSÃO
// =========================================

void CriarExplosao(Particula particulas[], Vector2 origem)
{
    for (int i = 0; i < MAX_PARTICULAS; i++)
    {
        if (!particulas[i].ativa)
        {
            particulas[i].ativa = true;
            particulas[i].posicao = origem;

            particulas[i].velocidade.x = GetRandomValue(-200, 200) / 100.0f;
            particulas[i].velocidade.y = GetRandomValue(-200, 200) / 100.0f;

            particulas[i].tamanho = GetRandomValue(3, 7);
            particulas[i].tempoVida = 0.8f;

            // Partículas brilham em AMARELO ao explodir
            particulas[i].cor = YELLOW; 
        }
    }
}

// =========================================
// MAIN
// =========================================

int main(void)
{
    // Cria janela na nova proporção de 1200x700 da câmera
    InitWindow(1200, 700, "Jogo da Minhoca - Camera 2D");

    SetTargetFPS(60);

    // =========================================
    // CARREGA TEXTURA E CONFIGURA FRAMES
    // =========================================

    Texture2D sprite = LoadTexture("player.png");

    int frames = 4;
    int frameAtual = 0;
    int larguraFrame = sprite.width / frames;
    int alturaFrame = sprite.height;
    
    float tempoAnimacao = 0;
    float velocidadAnimacao = 0.15f;

    // =========================================
    // VARIÁVEIS DO JOGO E DA CÂMERA
    // =========================================

    // Sistema de partículas
    Particula particulas[MAX_PARTICULAS] = { 0 };

    // Estado inicial
    GameState estadoAtual = MENU;

    // Posição inicial no mundo amplo
    Vector2 jogador = { 500, 500 };
    float velocidade = 4.0f;

    // Configuração da câmera 2D
    Camera2D camera = { 0 };
    camera.offset = (Vector2){ 600, 350 }; // Centro da tela (1200/2, 700/2)
    camera.target = jogador;               // Foca no jogador
    camera.rotation = 0.0f;
    camera.zoom = 1.0f;

    // Corpo da Minhoca
    Vector2 corpo[100];
    int tamanhoMinhoca = 3;

    // Comida espalhada pelo mapa
    Vector2 comida = { 800, 600 };

    // Variáveis da HUD
    int score = 0;
    int nivelVelocidade = 1;
    float tempo = 0;

    // =========================================
    // LOOP PRINCIPAL
    // =========================================

    while (!WindowShouldClose())
    {
        float delta = GetFrameTime();

        // =========================================
        // UPDATE DA ANIMAÇÃO DO SPREADSHEET
        // =========================================
        tempoAnimacao += delta;
        if (tempoAnimacao >= velocidadAnimacao)
        {
            frameAtual++;
            if (frameAtual >= frames) frameAtual = 0;
            tempoAnimacao = 0;
        }

        // =========================================
        // UPDATE DO JOGO
        // =========================================

        if (estadoAtual == MENU)
        {
            if (IsKeyPressed(KEY_ENTER))
            {
                jogador = (Vector2){ 500, 500 };
                tamanhoMinhoca = 3;
                for (int i = 0; i < tamanhoMinhoca; i++) corpo[i] = jogador;
                score = 0;
                tempo = 0;
                nivelVelocidade = 1;
                velocidade = 4.0f;
                camera.zoom = 1.0f;
                camera.rotation = 0.0f;
                
                for (int i = 0; i < MAX_PARTICULAS; i++) particulas[i].ativa = false;

                estadoAtual = GAME;
            }

            if (IsKeyPressed(KEY_I))     estadoAtual = INSTRUCTIONS;
            if (IsKeyPressed(KEY_ESCAPE)) break;
        }
        else if (estadoAtual == INSTRUCTIONS)
        {
            if (IsKeyPressed(KEY_BACKSPACE)) estadoAtual = MENU;
        }
        else if (estadoAtual == GAME)
        {
            tempo += delta;

            // Atualiza histórico do corpo
            for (int i = tamanhoMinhoca - 1; i > 0; i--)
            {
                corpo[i] = corpo[i - 1];
            }
            corpo[0] = jogador;

            // Movimentação
            if (IsKeyDown(KEY_RIGHT)) jogador.x += velocidade;
            if (IsKeyDown(KEY_LEFT))  jogador.x -= velocidade;
            if (IsKeyDown(KEY_UP))    jogador.y -= velocidade;
            if (IsKeyDown(KEY_DOWN))  jogador.y += velocidade;

            // Atualiza o foco da câmera para seguir a cabeça da minhoca
            camera.target = jogador;

            // Controle dinâmico do zoom com o mouse wheel
            camera.zoom += GetMouseWheelMove() * 0.1f;
            if (camera.zoom < 0.5f) camera.zoom = 0.5f;
            if (camera.zoom > 2.0f) camera.zoom = 2.0f;

            // Rotação da câmera pelas teclas Q e E
            if (IsKeyDown(KEY_Q)) camera.rotation -= 50 * delta;
            if (IsKeyDown(KEY_E)) camera.rotation += 50 * delta;

            // COLISÃO: Comeu a fruta amarela?
            if (CheckCollisionCircles(jogador, 15, comida, 10))
            {
                CriarExplosao(particulas, comida);

                score += 10;
                if (tamanhoMinhoca < 100) tamanhoMinhoca += 2;

                // Reposiciona a comida em uma área aleatória do mapa do mundo
                comida.x = (float)(GetRandomValue(-1500, 1500));
                comida.y = (float)(GetRandomValue(-1500, 1500));
            }

            // Mudar velocidade manualmente com ESPAÇO
            if (IsKeyPressed(KEY_SPACE))
            {
                nivelVelocidade++;
                velocidade += 0.5f;
                if (nivelVelocidade > 10)
                {
                    nivelVelocidade = 1;
                    velocidade = 4.0f;
                }
            }

            // Colisão com o corpo
            for (int i = 10; i < tamanhoMinhoca; i++)
            {
                if (CheckCollisionCircles(jogador, 12, corpo[i], 12))
                {
                    estadoAtual = GAME_OVER;
                }
            }

            if (IsKeyPressed(KEY_G)) estadoAtual = GAME_OVER;
        }
        else if (estadoAtual == GAME_OVER)
        {
            if (IsKeyPressed(KEY_R))
            {
                jogador = (Vector2){ 500, 500 };
                tamanhoMinhoca = 3;
                for (int i = 0; i < tamanhoMinhoca; i++) corpo[i] = jogador;
                score = 0;
                tempo = 0;
                estadoAtual = GAME;
            }
            if (IsKeyPressed(KEY_M)) estadoAtual = MENU;
        }

        // UPDATE DAS PARTÍCULAS
        for (int i = 0; i < MAX_PARTICULAS; i++)
        {
            if (particulas[i].ativa)
            {
                particulas[i].posicao.x += particulas[i].velocidade.x * 100 * delta;
                particulas[i].posicao.y += particulas[i].velocidade.y * 100 * delta;
                particulas[i].tempoVida -= delta;
                particulas[i].tamanho -= delta * 4;

                if (particulas[i].tempoVida <= 0 || particulas[i].tamanho <= 0)
                {
                    particulas[i].ativa = false;
                }
            }
        }

        // Configuração dos retângulos para renderizar a sprite
        Rectangle source = { frameAtual * larguraFrame, 0, larguraFrame, alturaFrame };
        Rectangle dest = { jogador.x, jogador.y, 40, 40 };
        Vector2 centroSprite = { 20, 20 };

        // =========================================
        // DRAW
        // =========================================

        BeginDrawing();
        ClearBackground(BLACK); // Fundo limpo para valorizar tons neon

        if (estadoAtual == MENU)
        {
            DrawText("MINHOCA ARCADE 2D", 400, 220, 36, PINK);
            DrawText("Pressione ENTER para iniciar", 410, 320, 24, YELLOW);
            DrawText("Pressione I para Instrucoes", 430, 370, 24, YELLOW);
        }
        else if (estadoAtual == INSTRUCTIONS)
        {
            DrawText("INSTRUCOES DO MAPA", 410, 150, 36, PINK);
            DrawText("Use as setas para se mover por todo o mapa espacial.", 310, 250, 22, YELLOW);
            DrawText("Scroll do Mouse altera o ZOOM | Teclas Q e E ROTACIONAM a tela.", 250, 300, 22, PINK);
            DrawText("Pressione BACKSPACE para voltar.", 420, 420, 22, YELLOW);
        }
        else if (estadoAtual == GAME)
        {
            // =========================================
            // COMEÇA MODO CÂMERA (Desenha coisas do mundo)
            // =========================================
            BeginMode2D(camera);

            // Grid estrutural do mundo amplo (Tons cinzas discretos)
            for (int x = -2000; x <= 2000; x += 100)
            {
                DrawLine(x, -2000, x, 2000, DARKGRAY);
            }
            for (int y = -2000; y <= 2000; y += 100)
            {
                DrawLine(-2000, y, 2000, y, DARKGRAY);
            }

            // Centro do Mapa (Marcador Amarelo discreto)
            DrawCircle(0, 0, 15, YELLOW);

            // Desenha Fruta (Bolinha Amarela) no mundo
            DrawCircleV(comida, 10, YELLOW);

            // Desenha o corpo em segmentos circulares em tom PINK
            for (int i = 0; i < tamanhoMinhoca; i++)
            {
                DrawCircleV(corpo[i], 12, PINK);
            }

            // Desenha a cabeça usando a sprite sheet animada e matiz PINK
            DrawTexturePro(sprite, source, dest, centroSprite, 0, PINK);

            // Desenha as partículas da explosão no mundo (Amarelas)
            for (int i = 0; i < MAX_PARTICULAS; i++)
            {
                if (particulas[i].ativa)
                {
                    DrawCircleV(particulas[i].posicao, particulas[i].tamanho, particulas[i].cor);
                }
            }

            EndMode2D();
            // =========================================
            // TERMINA MODO CÂMERA 
            // =========================================

            // =========================================
            // INTERFACE HUD FIXA NA TELA (Fora do Mode2D)
            // =========================================
            DrawRectangle(0, 0, 1200, 120, Fade(DARKGRAY, 0.85f));
            DrawLine(0, 120, 1200, 120, PINK);

            DrawText("SNAKE WORLD 2D", 20, 15, 28, YELLOW);
            DrawText(TextFormat("Frutas: %d", score / 10), 20, 65, 20, YELLOW);
            DrawText(TextFormat("Tamanho: %d", tamanhoMinhoca), 200, 65, 20, PINK);

            // Barra de Progresso
            DrawRectangle(200, 40, 200, 20, BLACK);
            DrawRectangle(200, 40, tamanhoMinhoca * 2, 20, PINK); 
            DrawRectangleLines(200, 40, 200, 20, YELLOW);         

            DrawText(TextFormat("Velocidade: Nivel %d", nivelVelocidade), 440, 65, 20, YELLOW);
            DrawText(TextFormat("Zoom: %.2f", camera.zoom), 680, 65, 20, PINK);
            DrawText(TextFormat("Tempo: %.1f s", tempo), 860, 65, 20, YELLOW);
            
            DrawText("ESPACO = Velocidade | Mouse Wheel = Zoom | Q/E = Rotacao", 20, 565, 18, YELLOW);
        }
        else if (estadoAtual == GAME_OVER)
        {
            DrawText("GAME OVER", 470, 200, 48, PINK);
            DrawText(TextFormat("Sua minhoca alcancou %d pontos", score), 450, 280, 22, YELLOW);
            DrawText("Pressione R para Reiniciar", 445, 360, 22, YELLOW);
            DrawText("Pressione M para ir ao Menu", 440, 400, 22, PINK);
        }

        EndDrawing();
    }

    // Libera texturas da memória
    UnloadTexture(sprite);
    CloseWindow();
    
    return 0;
}
