            if(hov&&IsMouseButtonPressed(MOUSE_LEFT_BUTTON)){
                START_MISSAO(M1,InitM1,dg1[0].x+40,dg1[0].y-52);
                degAtual=0;hpGanho=0;scrollFogo=0;fogoT=0;
            }

