static Rectangle plats5[12];
static float obsTimer5;
static int obsDestroyed5;
static bool topo5;

static void InitM5(void){
    float ps[][3]={{0,H-20,W},{80,660,90},{400,620,90},{60,540,100},
                   {350,490,100},{120,420,100},{380,360,90},{100,290,110},
                   {340,230,100},{80,165,120},{300,110,130},{150,50,180}};
    for(int i=0;i<12;i++) plats5[i]=(Rectangle){ps[i][0],ps[i][1],ps[i][2],14};
    for(int i=0;i<12;i++) obs[i].on=false;
    obsTimer5=0; obsDestroyed5=0; topo5=false;
    ResetParts();
}

static void SpawnObs(void){
    for(int i=0;i<12;i++) if(!obs[i].on){
        int tipo=GetRandomValue(0,2);
        obs[i].on=true; obs[i].tipo=tipo;
        if(tipo==0){ obs[i].x=(float)GetRandomValue(0,W); obs[i].y=-20; obs[i].vx=GetRandomValue(-20,20)/10.f; obs[i].vy=GetRandomValue(30,60)/10.f; }
        else if(tipo==1){ obs[i].x=(float)GetRandomValue(30,W-30); obs[i].y=-10; obs[i].vx=0; obs[i].vy=GetRandomValue(50,90)/10.f; }
        else { obs[i].x=(float)GetRandomValue(50,W-50); obs[i].y=(float)GetRandomValue(100,H-200); obs[i].vx=0; obs[i].vy=0; }
        break;
    }
}

static bool CheckObsHit(float bx,float by){
    Rectangle rb={(float)(bx+4),(float)by,24,52};
    for(int i=0;i<12;i++){if(!obs[i].on)continue;
        Rectangle ro;
        if(obs[i].tipo==0||obs[i].tipo==2) ro=(Rectangle){obs[i].x-16,obs[i].y-16,32,32};
        else ro=(Rectangle){obs[i].x-6,obs[i].y,12,40};
        if(CheckCollisionRecs(rb,ro)) return true;
    }
    return false;
}

static void UpdM5(float dt){
    obsTimer5+=dt;
    if(obsTimer5>0.8f){ obsTimer5=0; SpawnObs(); SpawnObs(); }
    for(int i=0;i<12;i++){if(!obs[i].on)continue;
        obs[i].x+=obs[i].vx*60*dt; obs[i].y+=obs[i].vy*60*dt;
        if(obs[i].tipo==2){
            obs[i].vy+=dt; if(obs[i].vy>1.5f)obs[i].on=false;
        } else if(obs[i].y>H+50) obs[i].on=false;
    }
    if(GetRandomValue(0,4)==0) EmitPart((float)GetRandomValue(0,W),(float)(H-20));
    UpdParts();
}

