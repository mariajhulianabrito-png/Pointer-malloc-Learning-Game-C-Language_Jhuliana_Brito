int main(void){
    InitWindow(W,H,"Bombeiro Heroi - 5 Missoes");
    SetTargetFPS(60);

    Estado st=MENU;
    int missao=1, chances=3, animFr=0;
    float bx=0,by=0,vy=0,timer=0,animT=0,vitT=0,rocketT=0;
    bool noChao=false, virado=true, vitoria=false;

    InitM1();
    ResetRockets();

    #define RESET_BOM(PX,PY) do{ bx=(PX); by=(PY); vy=0; noChao=false; }while(0)
    #define START_MISSAO(M, INITFN, PX, PY) do{ \
        st=(M); missao=(M)-1; timer=0; chances=3; vitoria=false; vitT=0; \
        INITFN(); RESET_BOM(PX,PY); ResetParts(); ResetRockets(); \
    }while(0)

    while(!WindowShouldClose()){
        float dt=GetFrameTime(); if(dt>0.05f)dt=0.05f;
        Vector2 mouse=GetMousePosition();

        animT+=dt; if(animT>0.09f){animFr++;animT=0;}

        if(vitoria){ vitT+=dt; rocketT+=dt;
            if(rocketT>0.35f){rocketT=0;LaunchRocket();}
            UpdFoguetes();
            if(vitT>3.5f && st!=VITFINAL){
                if(st==M1){START_MISSAO(M2,InitM2, camX2+45.f,(float)(H-160));}
                else if(st==M2){START_MISSAO(M3,InitM3, plats3[0].x+40,plats3[0].y-52);}
                else if(st==M3){START_MISSAO(M4,InitM4, camX4+45.f,(float)(H-160));}
                else if(st==M4){START_MISSAO(M5,InitM5, plats5[0].x+40,plats5[0].y-52);}
                else if(st==M5){ st=VITFINAL; vitoria=true; vitT=0; }
            }
        }

        bool usaPlataformer=(st==M1||st==M3||st==M5);
        Rectangle *plats_arr=NULL; int plats_n=0;
        if(st==M1){plats_arr=dg1;plats_n=ND;}
        else if(st==M3){plats_arr=plats3;plats_n=11;}
        else if(st==M5){plats_arr=plats5;plats_n=12;}

        if(usaPlataformer && !vitoria){
            timer+=dt;
            if(IsKeyDown(KEY_LEFT)||IsKeyDown(KEY_A)){bx-=4.5f;virado=false;}
            if(IsKeyDown(KEY_RIGHT)||IsKeyDown(KEY_D)){bx+=4.5f;virado=true;}
            if(bx<0)bx=0; if(bx>W-32)bx=W-32;
            if((IsKeyDown(KEY_SPACE)||IsKeyDown(KEY_UP)||IsKeyDown(KEY_W))&&noChao){vy=-14.f;noChao=false;}
            vy+=0.45f; by+=vy;
            noChao=false;
            Rectangle rb={(float)(bx+4),(float)by,24,52};
            for(int i=0;i<plats_n;i++){
                if(vy>0 && rb.x+rb.width>plats_arr[i].x && rb.x<plats_arr[i].x+plats_arr[i].width
                   && by+52>=plats_arr[i].y-2 && by+52<=plats_arr[i].y+plats_arr[i].height+8){
                    by=plats_arr[i].y-52; vy=0; noChao=true; break;
                }
            }
            if(by>H+30){chances--; if(chances<=0)st=GAMEOVER;
                else{bx=plats_arr[0].x+40;by=plats_arr[0].y-52;vy=0;}}
        }

        if(st==M1 && !vitoria){
            fogoT+=dt; if(fogoT>3.f){fogoT=0;scrollFogo+=18.f;}
            float altFogo=(float)(H-55)-scrollFogo;
            if(by+52>=altFogo){chances--;
                if(chances<=0)st=GAMEOVER;
                else{bx=dg1[degAtual].x+40;by=dg1[degAtual].y-52;vy=0;scrollFogo-=50;if(scrollFogo<0)scrollFogo=0;}}
            for(int i=0;i<ND;i++){
                Rectangle rb={(float)(bx+4),(float)by,24,52};
                if(vy>=0&&rb.x+rb.width>dg1[i].x&&rb.x<dg1[i].x+dg1[i].width
                   &&by+52>=dg1[i].y-2&&by+52<=dg1[i].y+dg1[i].height+8){
                    if(i>degAtual){hpGanho+=i-degAtual;degAtual=i;scrollFogo+=45.f*(i-degAtual);}
                    if(i==ND-1&&noChao)vitoria=true;
                }
            }
            if(GetRandomValue(0,3)==0) EmitPart((float)GetRandomValue(0,W),altFogo);
            UpdParts();
        }
        else if(st==M2 && !vitoria){
            timer+=dt; UpdM2(dt);
            if(fogoApagado2>=fogoTotal2&&fogoTotal2>0)vitoria=true;
        }
        else if(st==M3 && !vitoria){
            for(int i=0;i<5;i++){if(!vits[i].on||vits[i].salvo)continue;
                if(fabsf(bx-vits[i].x)<30&&fabsf(by-vits[i].y)<40){
                    vits[i].salvo=true;salvas3++;}}
            if(salvas3>=5)vitoria=true;
            if(GetRandomValue(0,5)==0) EmitPart((float)GetRandomValue(0,W),(float)(H-20));
            UpdParts();
        }
        else if(st==M4 && !vitoria){
            timer+=dt; UpdM4(dt); UpdParts();
            if(barrisApagados4>=6)vitoria=true;
        }
        else if(st==M5 && !vitoria){
            timer+=dt; UpdM5(dt);
            if(CheckObsHit(bx,by)){chances--;
                if(chances<=0)st=GAMEOVER;
                else{bx=plats5[0].x+40;by=plats5[0].y-52;vy=0;
                    for(int i=0;i<12;i++)obs[i].on=false;}}
